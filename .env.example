# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/eshabiki"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://yourdomain.com"

# Google Cloud Storage
GCS_BUCKET_NAME="eshabiki-assets"
GCS_PROJECT_ID="your-gcp-project-id"
# GCS_KEY_FILE=./secrets/gcs-key.json

# Encryption key for credentials (64 hex chars = 32 bytes)
ENCRYPTION_KEY="generate-with: openssl rand -hex 32"

# Postgres (docker-compose)
POSTGRES_USER="eshabiki"
POSTGRES_PASSWORD="strong-password"
POSTGRES_DB="eshabiki"

# NCBA C2B Payment API
NCBA_USERNAME="your-ncba-username"
NCBA_PASSWORD="your-ncba-password"
NCBA_PAYBILL_NO="880100"
NCBA_TILL_NO="your-till-number"
