generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMERATIONS
// ─────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum AdminPermission {
  MANAGE_USERS
  MANAGE_LISTINGS
  MANAGE_TRANSACTIONS
  MANAGE_DISPUTES
  MANAGE_CHALLENGES
  MANAGE_MESSAGES
  SEND_SUPPORT_EMAIL
  MANAGE_SHOP
  MANAGE_TOURNAMENTS
  MANAGE_FEES
  MANAGE_RANK_PUSH
}

enum AgentStatus {
  RUNNING
  STOPPED
  STARTING
  STOPPING
  ERROR
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING_VERIFICATION
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SOLD
  REMOVED
  EXPIRED
}

enum TransactionStatus {
  PENDING_PAYMENT
  IN_ESCROW
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum Platform {
  PS5
  PS4
  XBOX
  PC
  MOBILE
}

enum EscrowRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

enum EscrowPartyRole {
  BUYER
  SELLER
}

enum ChallengeFormat {
  BEST_OF_3
  BEST_OF_5
}

enum ChallengeMessageType {
  MATCH_CODE_REQUEST
  MATCH_CODE
}

enum ChallengeStatus {
  PENDING_HOST_PAYMENT
  OPEN
  ACTIVE
  SUBMITTED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MatchResult {
  HOST_WIN
  CHALLENGER_WIN
}

enum TournamentType {
  LEAGUE
  KNOCKOUT
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentMatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  WALKOVER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WalletTxType {
  CHALLENGE_WIN       // credited when you win a challenge
  CHALLENGE_WAGER     // debited when you pay wager from wallet
  PAYOUT              // debited when a payout is processed
  ADMIN_ADJUSTMENT    // manual credit/debit by admin
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// ─────────────────────────────────────────────
// CORE MODELS
// ─────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  emailVerified    DateTime?
  passwordHash     String?
  username         String     @unique
  displayName      String?
  avatarUrl        String?
  role             Role       @default(BUYER)
  status           UserStatus @default(ACTIVE)
  isVerifiedSeller Boolean    @default(false)
  isSuperAdmin     Boolean    @default(false)
  adminPermissions AdminPermission[]

  // AI agent fields (only set when isAgent = true)
  isAgent          Boolean     @default(false)
  agentHostUrl     String?
  agentApiKey      String?     // AES-256-GCM encrypted host API key
  agentStatus      AgentStatus @default(STOPPED)
  agentToken       String?     @unique // token for agent to call this app's API

  isRankPusher     Boolean     @default(false)

  bio              String?

  totalSales     Int   @default(0)
  totalPurchases Int   @default(0)
  rating         Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings         Listing[]     @relation("SellerListings")
  purchases        Transaction[] @relation("BuyerTransactions")
  sales            Transaction[] @relation("SellerTransactions")
  disputesRaised   Dispute[]     @relation("BuyerDisputes")
  adminActions     AdminAction[]
  reviews          Review[]      @relation("ReviewsGiven")
  reviewsReceived  Review[]      @relation("ReviewsReceived")
  notifications    Notification[]
  sentMessages           Message[]       @relation("SentMessages")
  receivedMessages       Message[]       @relation("ReceivedMessages")
  initiatedEscrowReqs    EscrowRequest[]    @relation("InitiatedEscrowRequests")
  receivedEscrowReqs     EscrowRequest[]    @relation("ReceivedEscrowRequests")
  challengesHosted       Challenge[]        @relation("ChallengeHost")
  challengesJoined       Challenge[]        @relation("ChallengeChallenger")
  challengesWon          Challenge[]        @relation("ChallengeWinner")
  challengeMessages      ChallengeMessage[] @relation("ChallengeSender")
  cart                   Cart?
  shopOrders             ShopOrder[]        @relation("UserShopOrders")
  tournamentEntries      TournamentParticipant[] @relation("TournamentParticipants")
  tournamentMatchesAsP1  TournamentMatch[]  @relation("TournamentMatchP1")
  tournamentMatchesAsP2  TournamentMatch[]  @relation("TournamentMatchP2")
  payments               Payment[]
  wallet                 Wallet?
  walletTransactions     WalletTransaction[]
  payoutRequests         PayoutRequest[]
  rankPushListings       RankPushListing[]  @relation("RankPushProviderListings")
  rankPushOrdersAsClient RankPushOrder[]    @relation("RankPushClient")
  rankPushOrdersAsProvider RankPushOrder[]  @relation("RankPushProvider")

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([status])
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("SellerListings", fields: [sellerId], references: [id])
  title       String
  description String        @db.Text
  price       Decimal       @db.Decimal(10, 2)
  currency    String        @default("KES")
  status      ListingStatus @default(PENDING_APPROVAL)

  accountLevel    Int?
  platform        Platform @default(PS5)
  region          String?
  division        String?
  coins           Int?
  gpAmount        Int?
  featuredPlayers String[]
  overallRating   Int?

  screenshots ListingImage[]

  approvedAt    DateTime?
  approvedBy    String?
  removalReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?
  views         Int       @default(0)
  isPrivateDeal Boolean   @default(false)

  transaction Transaction?

  @@index([sellerId])
  @@index([status])
  @@index([price])
  @@index([platform])
  @@index([createdAt])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  gcsKey    String
  order     Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Transaction {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id])

  buyerId  String
  buyer    User   @relation("BuyerTransactions", fields: [buyerId], references: [id])
  sellerId String
  seller   User   @relation("SellerTransactions", fields: [sellerId], references: [id])

  amount         Decimal @db.Decimal(10, 2)
  platformFee    Decimal @db.Decimal(10, 2)
  sellerReceives Decimal @db.Decimal(10, 2)
  currency       String  @default("KES")

  status TransactionStatus @default(PENDING_PAYMENT)

  paymentConfirmedAt   DateTime?
  deliveryDeadline     DateTime?
  confirmationDeadline DateTime?
  deliveredAt          DateTime?
  completedAt          DateTime?
  refundedAt           DateTime?

  credentialsDelivered Boolean @default(false)
  encryptedCredentials String? @db.Text

  dispute      Dispute?
  review       Review?
  adminActions AdminAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

model Dispute {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  raisedById String
  raisedBy   User   @relation("BuyerDisputes", fields: [raisedById], references: [id])

  reason   String        @db.Text
  evidence String[]
  status   DisputeStatus @default(OPEN)

  resolvedBy String?
  resolution String?   @db.Text
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([raisedById])
}

model Review {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  reviewerId String
  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  rating  Int
  comment String? @db.Text

  createdAt DateTime @default(now())

  @@index([revieweeId])
  @@index([reviewerId])
}

model AdminAction {
  id      String @id @default(cuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  targetUserId    String?
  targetListingId String?
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id])

  action   String
  note     String? @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
}

model Notification {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String
  title   String
  body    String
  isRead  Boolean @default(false)
  linkUrl String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id])
  content     String   @db.Text
  imageUrl    String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
  @@index([createdAt])
}

model EscrowRequest {
  id               String              @id @default(cuid())
  initiatorId      String
  initiator        User                @relation("InitiatedEscrowRequests", fields: [initiatorId], references: [id])
  counterpartyId   String
  counterparty     User                @relation("ReceivedEscrowRequests", fields: [counterpartyId], references: [id])

  // Role the INITIATOR is taking (counterparty gets the opposite)
  initiatorRole    EscrowPartyRole

  title            String
  description      String              @db.Text
  price            Decimal             @db.Decimal(10, 2)
  currency         String              @default("KES")

  status           EscrowRequestStatus @default(PENDING)

  // Seller verification screenshots (username, squad, reserves, managers, coins)
  sellerScreenshots String[]

  // Set once accepted and a transaction is created
  transactionId    String?             @unique

  expiresAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([initiatorId])
  @@index([counterpartyId])
  @@index([status])
}

model Challenge {
  id           String          @id @default(cuid())
  hostId       String
  host         User            @relation("ChallengeHost", fields: [hostId], references: [id])
  challengerId String?
  challenger   User?           @relation("ChallengeChallenger", fields: [challengerId], references: [id])

  format       ChallengeFormat
  wagerAmount  Decimal         @db.Decimal(12, 2)
  currency     String          @default("KES")
  status       ChallengeStatus @default(OPEN)
  description  String?         @db.Text

  hostSquadUrl       String
  challengerSquadUrl String?

  hostResult       MatchResult?
  challengerResult MatchResult?
  winnerId         String?
  winner           User?       @relation("ChallengeWinner", fields: [winnerId], references: [id])

  platformFee    Decimal? @db.Decimal(10, 2)
  transactionFee Decimal? @db.Decimal(10, 2)
  adminNote      String?  @db.Text

  // Time agreement — proposedMatchTime is the pending (unaccepted) suggestion
  proposedMatchTime DateTime?
  proposedByHost    Boolean?
  scheduledAt       DateTime?   // confirmed by both parties
  resultDeadlineAt  DateTime?

  expiresAt   DateTime
  completedAt DateTime?

  messages ChallengeMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hostId])
  @@index([challengerId])
  @@index([status])
  @@index([createdAt])
}

model ChallengeMessage {
  id          String               @id @default(cuid())
  challengeId String
  challenge   Challenge            @relation(fields: [challengeId], references: [id])
  senderId    String
  sender      User                 @relation("ChallengeSender", fields: [senderId], references: [id])
  messageType ChallengeMessageType @default(MATCH_CODE_REQUEST)
  content     String               @db.Text  // the match code for MATCH_CODE, ignored for REQUEST

  createdAt DateTime @default(now())

  @@index([challengeId, createdAt])
}

// ─────────────────────────────────────────────
// SHOP
// ─────────────────────────────────────────────

enum ProductType {
  PERIPHERAL
  MERCH
  GIFT_CARD
  IN_GAME_ITEM
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ShopOrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?   @db.Text
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
}

model Product {
  id          String          @id @default(cuid())
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  type        ProductType
  status      ProductStatus   @default(DRAFT)
  name        String
  slug        String          @unique
  description String          @db.Text
  price       Decimal         @db.Decimal(10, 2)
  currency    String          @default("KES")
  stock       Int             @default(0)
  imageKeys   String[]
  isFeatured  Boolean         @default(false)
  tags        String[]
  cartItems   CartItem[]
  orderItems  ShopOrderItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([isFeatured])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  @@unique([cartId, productId])
  @@index([cartId])
}

model ShopOrder {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation("UserShopOrders", fields: [userId], references: [id])
  status          ShopOrderStatus @default(PENDING_PAYMENT)
  total           Decimal         @db.Decimal(10, 2)
  currency        String          @default("KES")
  shippingName    String?
  shippingLine1   String?
  shippingCity    String?
  shippingCountry String?
  shippingPostal  String?
  trackingNumber  String?
  adminNote       String?         @db.Text
  items           ShopOrderItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ShopOrderItem {
  id          String    @id @default(cuid())
  orderId     String
  order       ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  productName String
  unitPrice   Decimal   @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal   @db.Decimal(10, 2)

  @@index([orderId])
}

model SiteConfig {
  id               String   @id @default("singleton")
  platformFeeRate  Decimal  @default(0.050) @db.Decimal(4, 3)
  buyerWindowDays  Int      @default(3)
  sellerWindowDays Int      @default(2)
  maintenanceMode  Boolean  @default(false)
  challengeResultWindowMinutes Int @default(60)
  minWagerAmount   Decimal  @default(0)   @db.Decimal(10, 2)
  maxWagerAmount   Decimal? @db.Decimal(10, 2)
  // Match code format — regex used to validate codes players share in chat
  matchCodePattern String   @default("^\\d{4}-?\\d{4}$")
  matchCodeHint    String   @default("8 digits, e.g. 12345678 or 1234-5678")
  // Admin receives email notifications at this address for key events
  adminNotificationEmail String?
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────
// PLATFORM FEES
// ─────────────────────────────────────────────

model PlatformFeeRule {
  id              String   @id @default(cuid())
  label           String
  minWager        Decimal  @db.Decimal(10, 2)
  maxWager        Decimal  @db.Decimal(10, 2)
  fee             Decimal  @db.Decimal(10, 2)   // platform profit fee
  transactionFee  Decimal  @default(0) @db.Decimal(10, 2) // payout processing fee
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────
// TOURNAMENTS
// ─────────────────────────────────────────────

model Tournament {
  id              String                  @id @default(cuid())
  name            String
  slug            String                  @unique
  game            String
  type            TournamentType
  status          TournamentStatus        @default(DRAFT)
  maxParticipants Int
  requiresPayment Boolean                 @default(false)
  entryFee        Decimal                 @default(0) @db.Decimal(10, 2)
  prizePool       Decimal                 @default(0) @db.Decimal(10, 2)
  currency        String                  @default("KES")
  description     String?                 @db.Text
  rules           String?                 @db.Text
  imageKey        String?
  startDate       DateTime?
  endDate         DateTime?
  participants    TournamentParticipant[]
  matches         TournamentMatch[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([status])
  @@index([type])
  @@index([slug])
}

model TournamentParticipant {
  id                String     @id @default(cuid())
  tournamentId      String
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId            String
  user              User       @relation("TournamentParticipants", fields: [userId], references: [id])
  seed              Int?
  teamName          String?
  squadScreenshotKey String?
  joinedAt          DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model TournamentMatch {
  id           String                @id @default(cuid())
  tournamentId String
  tournament   Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  matchNumber  Int
  player1Id    String?
  player1      User?                 @relation("TournamentMatchP1", fields: [player1Id], references: [id])
  player2Id    String?
  player2      User?                 @relation("TournamentMatchP2", fields: [player2Id], references: [id])
  player1Score Int?
  player2Score Int?
  winnerId     String?
  status              TournamentMatchStatus @default(SCHEDULED)
  scheduledAt         DateTime?
  completedAt         DateTime?
  nextMatchId         String?
  player1ResultKey    String?
  player2ResultKey    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tournamentId])
  @@index([round])
}

// ─────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WalletTransaction {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        WalletTxType
  amount      Decimal      @db.Decimal(12, 2)   // always positive; sign is in type
  balanceAfter Decimal     @db.Decimal(12, 2)
  description String
  challengeId String?
  payoutId    String?
  createdAt   DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([challengeId])
}

model PayoutRequest {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  amount      Decimal      @db.Decimal(12, 2)
  phone       String
  status      PayoutStatus @default(PENDING)
  adminNote   String?      @db.Text
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("KES")
  phone             String
  ncbaTransactionId String?
  referenceId       String?
  status            PaymentStatus @default(PENDING)
  // purpose: "escrow" | "challenge" | "tournament" | "shop" | "rank_push"
  purpose           String
  // entityId: transactionId / challengeId / tournamentId / orderId
  entityId          String
  // JSON metadata (e.g. challengerSquadUrl for challenge payments)
  metadata          String?       @db.Text
  failureReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([ncbaTransactionId])
  @@index([entityId])
  @@index([status])
}

// ─────────────────────────────────────────────
// RANK PUSH
// ─────────────────────────────────────────────

enum RankPushOrderStatus {
  PENDING_PAYMENT
  IN_PROGRESS
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
}

model RankPushCategory {
  id        String            @id @default(cuid())
  name      String
  sortOrder Int               @default(0)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  listings  RankPushListing[]
}

model RankPushListing {
  id          String           @id @default(cuid())
  providerId  String
  provider    User             @relation("RankPushProviderListings", fields: [providerId], references: [id])
  categoryId  String
  category    RankPushCategory @relation(fields: [categoryId], references: [id])
  title       String
  description String?          @db.Text
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("KES")
  isActive    Boolean          @default(true)
  orders      RankPushOrder[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([providerId])
  @@index([categoryId])
  @@index([isActive])
}

model RankPushOrder {
  id           String              @id @default(cuid())
  listingId    String
  listing      RankPushListing     @relation(fields: [listingId], references: [id])
  clientId     String
  client       User                @relation("RankPushClient", fields: [clientId], references: [id])
  providerId   String
  provider     User                @relation("RankPushProvider", fields: [providerId], references: [id])
  squadUrl     String
  amount       Decimal             @db.Decimal(10, 2)
  platformFee  Decimal             @db.Decimal(10, 2)
  providerGets Decimal             @db.Decimal(10, 2)
  currency     String              @default("KES")
  status       RankPushOrderStatus @default(PENDING_PAYMENT)
  notes        String?             @db.Text
  deliveryNote String?             @db.Text
  completedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([clientId])
  @@index([providerId])
  @@index([status])
}
